<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    package="com.huimantaoxiang.app">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.HuiManTaoXiang"
        android:usesCleartextTraffic="true">
        <activity
            android:name=".LoginActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        <activity
            android:name=".RegisterActivity"
            android:exported="false" />
        <activity
            android:name="com.huimantaoxiang.app.MainActivity"
            android:exported="false" />
        <activity
            android:name="com.huimantaoxiang.app.TaobaoAIActivity"
            android:exported="false"
            android:label="@string/taobao_ai_title" />
        <activity
            android:name="com.huimantaoxiang.app.CommunityActivity"
            android:exported="false" />
        <activity
            android:name="com.huimantaoxiang.app.PeachWorkshopActivity"
            android:exported="false"
            android:label="桃源工坊" />
        <activity
            android:name=".IdentifyPeachActivity"
            android:screenOrientation="portrait" />
        <activity
            android:name=".WarehouseActivity"
            android:exported="false"
            android:label="仓库管理" />
        <activity
            android:name=".CarbonMarketActivity"
            android:exported="false"
            android:label="碳汇市场" />
    </application>

</manifest>