<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_pink_peach"
    android:fitsSystemWindows="true"
    tools:context="com.huimantaoxiang.app.MainActivity">

    <!-- 装饰性背景圆形（营造氛围感） -->
    <View
        android:id="@+id/decor_circle_1"
        android:layout_width="200dp"
        android:layout_height="200dp"
        android:background="@drawable/decorative_circle"
        android:alpha="0.04"
        android:layout_marginTop="-80dp"
        android:layout_marginStart="-80dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <View
        android:id="@+id/decor_circle_2"
        android:layout_width="150dp"
        android:layout_height="150dp"
        android:background="@drawable/decorative_circle"
        android:alpha="0.06"
        android:layout_marginEnd="-50dp"
        android:layout_marginBottom="100dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <View
        android:id="@+id/decor_circle_3"
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:background="@drawable/decorative_circle"
        android:alpha="0.03"
        android:layout_marginBottom="-40dp"
        android:layout_marginStart="50dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- 顶部标题栏 -->
    <LinearLayout
        android:id="@+id/header_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@null"
        android:paddingTop="32dp"
        android:paddingBottom="16dp"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:elevation="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- 主标题 -->
        <TextView
            android:id="@+id/tv_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/title_app"
            android:textSize="30sp"
            android:textColor="#2B2B2B"
            android:fontFamily="serif"
            android:textStyle="bold"
            android:letterSpacing="0.02" />

        <!-- 副标题 -->
        <TextView
            android:id="@+id/tv_subtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="智慧农业 · 桃乡新篇"
            android:textSize="13sp"
            android:textColor="#8A8A8A"
            android:fontFamily="sans-serif"
            android:layout_marginTop="6dp"
            android:letterSpacing="0.15" />

        <!-- 退出登录入口 -->
        <TextView
            android:id="@+id/tv_logout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:layout_marginHorizontal="20dp"
            android:gravity="center"
            android:padding="12dp"
            android:text="退出登录"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold"
            android:background="@drawable/shape_button_logout"
            android:clickable="true"
            android:focusable="true" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="10dp"
            android:background="#1A000000" />
    </LinearLayout>

    <!-- 欢迎标语 -->
    <TextView
        android:id="@+id/tv_welcome"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="探索智慧农业的无限可能"
        android:textSize="14sp"
        android:textColor="#8A8A8A"
        android:fontFamily="sans-serif"
        android:layout_marginTop="20dp"
        android:letterSpacing="0.03"
        app:layout_constraintTop_toBottomOf="@id/header_container"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- 功能按钮网格 - 两行三列，居中对称 -->
    <GridLayout
        android:id="@+id/function_grid"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:columnCount="3"
        android:rowCount="2"
        android:background="@drawable/bg_function_grid"
        android:padding="12dp"
        app:layout_constraintTop_toBottomOf="@id/tv_welcome"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- 第一行 -->
        <include layout="@layout/item_function_button"
            android:id="@+id/btn_identify"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:layout_gravity="fill_horizontal"
            android:layout_margin="6dp" />

        <include layout="@layout/item_function_button"
            android:id="@+id/btn_shop"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:layout_gravity="fill_horizontal"
            android:layout_margin="6dp" />

        <include layout="@layout/item_function_button"
            android:id="@+id/btn_community"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:layout_gravity="fill_horizontal"
            android:layout_margin="6dp" />

        <!-- 第二行 -->
        <include layout="@layout/item_function_button"
            android:id="@+id/btn_workshop"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:layout_gravity="fill_horizontal"
            android:layout_margin="6dp" />

        <include layout="@layout/item_function_button"
            android:id="@+id/btn_irrigation"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:layout_gravity="fill_horizontal"
            android:layout_margin="6dp" />

        <include layout="@layout/item_function_button"
            android:id="@+id/btn_price"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:layout_gravity="fill_horizontal"
            android:layout_margin="6dp" />

    </GridLayout>

    <!-- 库存统计卡片 - 优化版 -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginTop="28dp"
        app:cardCornerRadius="20dp"
        app:cardElevation="4dp"
        app:cardBackgroundColor="#F2FFFFFF"
        app:strokeWidth="1dp"
        app:strokeColor="#0D000000"
        app:layout_constraintTop_toBottomOf="@id/function_grid"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <!-- 标题 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="20dp">

                <View
                    android:layout_width="4dp"
                    android:layout_height="20dp"
                    android:background="@drawable/gradient_indicator" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="库存分布"
                    android:textSize="18sp"
                    android:textColor="#2B2B2B"
                    android:textStyle="bold"
                    android:layout_marginStart="12dp"
                    android:fontFamily="sans-serif-medium" />
            </LinearLayout>

            <!-- 扇形图和图例 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <!-- 扇形图 -->
                <com.huimantaoxiang.app.PieChartView
                    android:id="@+id/pieChart"
                    android:layout_width="0dp"
                    android:layout_height="220dp"
                    android:layout_weight="1" />

                <!-- 图例 -->
                <LinearLayout
                    android:id="@+id/legendContainer"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="20dp"
                    android:gravity="center" />
            </LinearLayout>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- 底部版权信息 -->
    <TextView
        android:id="@+id/tv_copyright"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="© 2025 智桃科研 · 智慧农业"
        android:textSize="11sp"
        android:textColor="#8A8A8A"
        android:padding="16dp"
        android:fontFamily="sans-serif-light"
        android:gravity="center"
        android:letterSpacing="0.05"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
