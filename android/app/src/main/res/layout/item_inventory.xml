<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:padding="12dp"
    android:gravity="center_vertical"
    android:background="@drawable/bg_inventory_item">

    <!-- 左侧颜色标识 -->
    <View
        android:id="@+id/viewColorIndicator"
        android:layout_width="4dp"
        android:layout_height="40dp"
        android:background="@drawable/bg_color_indicator"
        android:layout_marginEnd="12dp" />

    <!-- 产品信息 -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvProductName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="水蜜桃"
            android:textSize="16sp"
            android:textColor="#2C3E50"
            android:textStyle="bold"
            android:fontFamily="sans-serif-medium" />

        <TextView
            android:id="@+id/tvProductDetails"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="鲜桃 | 库存: 120"
            android:textSize="13sp"
            android:textColor="#666666"
            android:layout_marginTop="2dp" />
    </LinearLayout>

    <!-- 删除按钮 -->
    <ImageButton
        android:id="@+id/btnDelete"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:src="@drawable/ic_delete"
        android:background="@drawable/bg_delete_button"
        android:contentDescription="删除"
        android:padding="8dp"
        android:scaleType="centerInside" />
</LinearLayout>
