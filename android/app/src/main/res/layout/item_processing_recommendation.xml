<?xml version="1.0" encoding="utf-8"?>
<!-- 加工建议卡片布局 -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="12dp"
    android:background="@drawable/bg_result_card_peach"
    android:orientation="vertical"
    android:padding="16dp">

    <!-- 标题栏 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:layout_marginBottom="12dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="💡 智能加工建议"
            android:textColor="@color/color_card_identify"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tv_match_score"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_match_score_badge"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:text="匹配度 95%"
            android:textColor="@color/white"
            android:textSize="12sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- 加工类型大标题 -->
    <TextView
        android:id="@+id/tv_processing_type"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"
        android:gravity="center"
        android:text="🍑 桃干加工"
        android:textColor="@color/deep_purple_text"
        android:textSize="24sp"
        android:textStyle="bold" />

    <!-- 推荐等级标签 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:layout_marginBottom="16dp">

        <TextView
            android:id="@+id/tv_recommendation_level"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/gradient_peach_header"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="8dp"
            android:paddingBottom="8dp"
            android:text="⭐⭐⭐⭐⭐ 强烈推荐"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- 原因说明 -->
    <TextView
        android:id="@+id/tv_recommendation_reason"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:background="@android:color/white"
        android:padding="12dp"
        android:text="高甜度且果肉厚实，脱水后口感浓郁，糖分保存率高"
        android:textColor="@color/deep_purple_text"
        android:textSize="15sp"
        android:lineSpacingExtra="4dp" />

    <!-- 关键指标展示 -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"
        android:text="📊 关键指标分析"
        android:textColor="@color/color_card_identify"
        android:textSize="14sp"
        android:textStyle="bold" />

    <!-- 指标列表 -->
    <LinearLayout
        android:id="@+id/ll_key_indicators"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        android:orientation="vertical" />

    <!-- 优势说明 -->
    <TextView
        android:id="@+id/tv_advantages"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"
        android:text="✨ 优势：营养丰富 | 保存期长 | 运输方便"
        android:textColor="@color/color_card_identify"
        android:textSize="13sp" />

    <!-- 加工提示 -->
    <TextView
        android:id="@+id/tv_processing_tips"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/white"
        android:padding="10dp"
        android:text="💡 加工提示：建议选用完全成熟的果实，去皮去核后切片晾晒"
        android:textColor="@color/deep_purple_text"
        android:textSize="13sp"
        android:lineSpacingExtra="2dp" />

</LinearLayout>
