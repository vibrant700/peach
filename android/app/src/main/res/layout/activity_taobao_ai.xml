<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/taobao_ai_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFF8FA">

    <View
        android:id="@+id/header_bg"
        android:layout_width="0dp"
        android:layout_height="180dp"
        android:background="@drawable/gradient_peach_header"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <LinearLayout
        android:id="@+id/btn_back"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_marginStart="16dp"
        android:layout_marginTop="12dp"
        android:gravity="center"
        android:clickable="true"
        android:focusable="true"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <ImageView
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:src="@drawable/ic_back"
            android:tint="#FFFFFFFF"
            android:contentDescription="返回" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/header_actions"
        android:layout_width="wrap_content"
        android:layout_height="40dp"
        android:layout_marginEnd="16dp"
        android:layout_marginTop="12dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <FrameLayout
            android:id="@+id/btn_mode"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:alpha="0.35"
            android:background="@drawable/circle_background_white"
            android:clickable="true"
            android:focusable="true">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:text="···"
                android:textStyle="bold"
                android:textSize="16sp"
                android:textColor="#FFFFFFFF" />
        </FrameLayout>

        <FrameLayout
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_marginStart="12dp"
            android:alpha="0.35"
            android:background="@drawable/circle_background_white">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_camera"
                android:tint="#FFFFFFFF"
                android:contentDescription="@null" />
        </FrameLayout>
    </LinearLayout>

    <ImageView
        android:id="@+id/iv_peach_logo"
        android:layout_width="38dp"
        android:layout_height="38dp"
        android:src="@drawable/ic_big_peach"
        android:contentDescription="@null"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/quick_actions_card"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <androidx.cardview.widget.CardView
        android:id="@+id/quick_actions_card"
        android:layout_width="0dp"
        android:layout_height="54dp"
        android:layout_marginStart="18dp"
        android:layout_marginEnd="18dp"
        android:layout_marginTop="64dp"
        app:cardBackgroundColor="#F2FFFFFF"
        app:cardCornerRadius="18dp"
        app:cardElevation="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="horizontal">

            <ImageView
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@drawable/ic_peach_outline"
                android:tint="#FF6F91"
                android:contentDescription="@null" />

            <ImageView
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:layout_marginStart="10dp"
                android:src="@drawable/ic_peach_outline"
                android:tint="#FF6F91"
                android:contentDescription="@null" />

            <ImageView
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:layout_marginStart="10dp"
                android:src="@drawable/ic_peach_outline"
                android:tint="#FF6F91"
                android:contentDescription="@null" />

            <ImageView
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:layout_marginStart="10dp"
                android:src="@drawable/ic_peach_outline"
                android:tint="#FF6F91"
                android:contentDescription="@null" />

            <ImageView
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:layout_marginStart="10dp"
                android:src="@drawable/ic_peach_outline"
                android:tint="#FF6F91"
                android:contentDescription="@null" />

            <ImageView
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:layout_marginStart="10dp"
                android:src="@drawable/ic_peach_outline"
                android:tint="#FF6F91"
                android:contentDescription="@null" />
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <TextView
        android:id="@+id/tv_title_ai"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:text="AI"
        android:textStyle="bold"
        android:textSize="16sp"
        android:textColor="#1F1F1F"
        app:layout_constraintTop_toBottomOf="@id/quick_actions_card"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- 消息列表区域 -->
    <ScrollView
        android:id="@+id/scroll"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="12dp"
        android:fillViewport="true"
        android:padding="8dp"
        app:layout_constraintTop_toBottomOf="@id/tv_title_ai"
        app:layout_constraintBottom_toTopOf="@id/input_container"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:id="@+id/container_messages"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="8dp" />
    </ScrollView>

    <!-- 加载指示器 -->
    <ProgressBar
        android:id="@+id/progress"
        style="?android:attr/progressBarStyleLarge"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:indeterminateTint="#FF69B4"
        app:layout_constraintTop_toTopOf="@id/scroll"
        app:layout_constraintBottom_toBottomOf="@id/scroll"
        app:layout_constraintStart_toStartOf="@id/scroll"
        app:layout_constraintEnd_toEndOf="@id/scroll" />

    <!-- 输入区域 -->
    <LinearLayout
        android:id="@+id/input_container"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="16dp"
        android:orientation="horizontal"
        android:padding="8dp"
        android:gravity="center_vertical"
        android:background="@android:color/transparent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:id="@+id/iv_ai_avatar"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@drawable/circle_background_white"
            android:padding="6dp"
            android:src="@drawable/avatar"
            android:contentDescription="@null" />

        <EditText
            android:id="@+id/input_message"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="12dp"
            android:hint="请输入"
            android:minHeight="48dp"
            android:background="@drawable/bg_chat_input"
            android:paddingStart="16dp"
            android:paddingEnd="8dp"
            android:paddingTop="12dp"
            android:paddingBottom="12dp"
            android:textSize="15sp"
            android:textColor="#2C3E50"
            android:textColorHint="#7F8C8D"
            android:fontFamily="sans-serif"
            android:inputType="textMultiLine"
            android:maxLines="4" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_send"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginStart="10dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:padding="0dp"
            app:icon="@drawable/ic_send"
            app:iconSize="20dp"
            app:iconTint="@color/white"
            app:cornerRadius="24dp"
            app:backgroundTint="#FF69B4"
            app:elevation="2dp"
            android:contentDescription="发送" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
