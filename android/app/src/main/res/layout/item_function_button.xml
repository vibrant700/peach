<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="100dp"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="16dp"
    android:background="@drawable/bg_function_button"
    android:clickable="true"
    android:focusable="true">

    <!-- 图标容器 -->
    <FrameLayout
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:background="@drawable/bg_icon_gradient">

        <ImageView
            android:id="@+id/iv_function_icon"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_menu_identify"
            android:contentDescription="@string/function_icon_desc" />
    </FrameLayout>

    <!-- 功能名称 -->
    <TextView
        android:id="@+id/tv_function_name"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="识桃"
        android:textSize="14sp"
        android:textColor="#2C3E50"
        android:fontFamily="sans-serif-medium"
        android:letterSpacing="0.02" />

</LinearLayout>
