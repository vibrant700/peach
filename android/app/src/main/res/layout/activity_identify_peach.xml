<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F7FA">

    <!-- 装饰背景圆形 -->
    <View
        android:id="@+id/decor_circle_1"
        android:layout_width="180dp"
        android:layout_height="180dp"
        android:background="@drawable/decorative_circle"
        android:alpha="0.04"
        android:layout_marginTop="-60dp"
        android:layout_marginEnd="-60dp" />

    <View
        android:id="@+id/decor_circle_2"
        android:layout_width="140dp"
        android:layout_height="140dp"
        android:background="@drawable/decorative_circle"
        android:alpha="0.03"
        android:layout_marginBottom="-50dp"
        android:layout_marginStart="-50dp" />

    <!-- 顶部标题栏 -->
    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/gradient_peach_header"
        android:elevation="6dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="24dp"
            android:paddingBottom="20dp"
            android:paddingStart="20dp"
            android:paddingEnd="20dp">

            <!-- 返回按钮和标题 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <LinearLayout
                    android:id="@+id/btn_back"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@drawable/bg_back_button"
                    android:paddingStart="12dp"
                    android:paddingEnd="16dp"
                    android:paddingTop="8dp"
                    android:paddingBottom="8dp"
                    android:clickable="true"
                    android:focusable="true">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_back"
                        android:contentDescription="返回"
                        android:tint="@color/white" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="首页"
                        android:textSize="15sp"
                        android:textColor="@color/white"
                        android:textStyle="bold"
                        android:layout_marginStart="6dp" />
                </LinearLayout>

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="桃子智能识别"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:textColor="@color/white"
                    android:layout_marginStart="16dp"
                    android:fontFamily="sans-serif-medium" />

                <ImageView
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@drawable/ic_peach_outline"
                    android:contentDescription="桃子"
                    android:tint="@color/white"
                    android:alpha="0.9" />
            </LinearLayout>

            <!-- 功能说明 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="12dp"
                android:background="#80000000"
                android:padding="12dp"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="上传桃子照片，AI将自动识别品种、成熟度、甜度等信息"
                    android:textSize="14sp"
                    android:textColor="#FFFFFFFF"
                    android:lineSpacingExtra="4dp"
                    android:fontFamily="sans-serif" />
            </LinearLayout>
        </LinearLayout>
    </com.google.android.material.appbar.AppBarLayout>

    <!-- 主内容区域 -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- 图片对比区域 -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                app:strokeWidth="1dp"
                app:strokeColor="@color/light_peach_bg">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="图像对比"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/deep_purple_text"
                        android:layout_marginBottom="16dp"
                        android:fontFamily="sans-serif-medium" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center">

                        <!-- 原始图片 -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center">

                            <androidx.cardview.widget.CardView
                                android:layout_width="120dp"
                                android:layout_height="120dp"
                                app:cardCornerRadius="16dp"
                                app:cardElevation="2dp"
                                app:cardBackgroundColor="@color/white"
                                app:strokeWidth="1dp"
                                app:strokeColor="@color/light_peach_bg">

                                <ImageView
                                    android:id="@+id/iv_preview"
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:contentDescription="原始图片"
                                    android:scaleType="centerCrop"
                                    android:padding="8dp"
                                    android:src="@drawable/ic_upload" />
                            </androidx.cardview.widget.CardView>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="原始图片"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:textColor="@color/deep_purple_text"
                                android:layout_marginTop="12dp"
                                android:fontFamily="sans-serif-medium" />
                        </LinearLayout>

                        <!-- 对比箭头 -->
                        <ImageView
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:layout_marginHorizontal="12dp"
                            android:src="@drawable/ic_refresh_peach"
                            android:contentDescription="对比"
                            android:tint="@color/deep_purple_text" />

                        <!-- 识别结果图片 -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center">

                            <androidx.cardview.widget.CardView
                                android:layout_width="120dp"
                                android:layout_height="120dp"
                                app:cardCornerRadius="16dp"
                                app:cardElevation="2dp"
                                app:cardBackgroundColor="@color/white"
                                app:strokeWidth="1dp"
                                app:strokeColor="@color/light_peach_bg">

                                <ImageView
                                    android:id="@+id/iv_result"
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:contentDescription="识别结果"
                                    android:scaleType="centerCrop"
                                    android:padding="8dp"
                                    android:src="@drawable/ic_upload"
                                    android:alpha="0.5" />
                            </androidx.cardview.widget.CardView>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="识别结果"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:textColor="@color/deep_purple_text"
                                android:layout_marginTop="12dp"
                                android:fontFamily="sans-serif-medium" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- 上传按钮 -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_upload"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginBottom="16dp"
                android:text="上传桃子照片"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/deep_purple_text"
                app:cornerRadius="24dp"
                app:backgroundTint="@null"
                android:background="@drawable/btn_upload_peach_selector"
                app:icon="@drawable/ic_peach_upload"
                app:iconTint="@color/deep_purple_text"
                app:iconGravity="textStart"
                app:elevation="4dp" />

            <!-- 模型选择卡片 -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="3dp"
                app:cardBackgroundColor="@color/white"
                app:strokeWidth="1dp"
                app:strokeColor="@color/light_peach_bg">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="12dp">

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_gear_leaf"
                            android:contentDescription="模型"
                            android:layout_marginEnd="8dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="选择识别模型"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="@color/deep_purple_text"
                            android:fontFamily="sans-serif-medium" />
                    </LinearLayout>

                    <Spinner
                        android:id="@+id/spinner_model"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:background="@drawable/bg_spinner_peach"
                        android:popupBackground="@drawable/dropdown_background"
                        android:paddingHorizontal="16dp"
                        android:textColor="@color/deep_purple_text"
                        android:fontFamily="sans-serif" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- 识别按钮 -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_identify"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginBottom="16dp"
                android:text="开始识别"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/white"
                app:cornerRadius="24dp"
                app:backgroundTint="@null"
                android:background="@drawable/btn_identify_selector"
                app:icon="@drawable/ic_identify_peach"
                app:iconTint="@color/white"
                app:iconSize="24dp"
                app:iconGravity="textStart"
                app:elevation="4dp" />

            <!-- 结果区域 -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@color/light_peach_bg"
                app:strokeWidth="1dp"
                app:strokeColor="@color/deep_purple_text">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="16dp">

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_list_peach"
                            android:contentDescription="结果"
                            android:layout_marginEnd="8dp" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="识别结果"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="@color/deep_purple_text"
                            android:fontFamily="sans-serif-medium" />
                    </LinearLayout>

                    <ScrollView
                        android:id="@+id/scroll_results"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:visibility="gone">

                        <LinearLayout
                            android:id="@+id/ll_results"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical" />
                    </ScrollView>

                    <!-- 加载进度区域 -->
                    <LinearLayout
                        android:id="@+id/layout_loading"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:visibility="gone"
                        android:paddingVertical="40dp">

                        <ProgressBar
                            android:id="@+id/progress_loading"
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:indeterminateTint="@color/deep_purple_text" />

                        <TextView
                            android:id="@+id/tv_loading_hint"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="识别中..."
                            android:textSize="16sp"
                            android:textColor="@color/deep_purple_text"
                            android:fontFamily="sans-serif-medium"
                            android:layout_marginTop="16dp" />
                    </LinearLayout>

                    <!-- 空状态提示 -->
                    <LinearLayout
                        android:id="@+id/empty_state_container"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:paddingVertical="40dp">

                        <ImageView
                            android:layout_width="80dp"
                            android:layout_height="80dp"
                            android:src="@drawable/ic_peach_placeholder"
                            android:contentDescription="桃子占位符"
                            android:alpha="0.5" />

                        <TextView
                            android:id="@+id/tv_empty_result"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="📸 请上传桃子照片"
                            android:textSize="14sp"
                            android:textColor="@color/light_purple_text"
                            android:layout_marginTop="20dp"
                            android:fontFamily="sans-serif"
                            android:gravity="center" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="AI将为您识别品种、成熟度、甜度"
                            android:textSize="12sp"
                            android:textColor="@color/light_purple_text"
                            android:alpha="0.8"
                            android:layout_marginTop="8dp"
                            android:fontFamily="sans-serif"
                            android:gravity="center" />
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
